---
---

<div id="customNotification" class="notification-toast">
  <div class="notification-content">
    <span class="notification-icon">⚠️</span>
    <p id="notificationText">Ничего не найдено</p>
    <button id="closeNotificationBtn" class="close-btn" aria-label="Закрыть">&times;</button>
  </div>
</div>

<style>
  .notification-toast {
    position: fixed;
    top: 24px;
    right: 24px;
    background-color: #1e293b;
    border: 1px solid rgba(239, 68, 68, 0.4);
    box-shadow:
      0 10px 25px -5px rgba(0, 0, 0, 0.5),
      0 0 12px rgba(239, 68, 68, 0.1);
    border-radius: 0.75rem;
    padding: 1rem 1.25rem;
    z-index: 1000;
    max-width: 400px;
    transform: translateX(120%);
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  :global(.notification-toast.visible) {
    transform: translateX(0);
  }

  .notification-content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .notification-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .notification-content p {
    margin: 0;
    font-size: 0.95rem;
    color: #f8fafc;
    line-height: 1.4;
    font-weight: 500;
  }

  .close-btn {
    background: none;
    border: none;
    color: #94a3b8;
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0 0 0 0.5rem;
    line-height: 1;
    transition: color 0.2s;
    margin-left: auto;
  }

  .close-btn:hover {
    color: #f8fafc;
  }
</style>
