---
interface Props {
  allGenres: string[];
  minYear: number;
  maxYear: number;
}

const { allGenres, minYear, maxYear } = Astro.props;
---

<aside class="sidebar-filters">
  <div class="type-selector">
    <input type="radio" id="typeMovie" name="contentType" value="movie" checked />
    <label for="typeMovie">🎬 Фильмы</label>

    <input type="radio" id="typeSeries" name="contentType" value="tv-series" />
    <label for="typeSeries">🍿 Сериалы</label>
  </div>

  <h2 class="sidebar-title">Настройки поиска</h2>

  <div class="filter-group">
    <label for="genreSelect">Жанр</label>
    <div class="select-wrapper">
      <select id="genreSelect">
        <option value="">Любой жанр</option>
        {allGenres.map((genre) => <option value={genre}>{genre.charAt(0).toUpperCase() + genre.slice(1)}</option>)}
      </select>
    </div>
  </div>

  <div class="filter-group">
    <label for="countrySelect">Производство</label>
    <div class="select-wrapper">
      <select id="countrySelect">
        <option value="all">Все страны</option>
        <option value="ru">Российские</option>
        <option value="foreign">Зарубежные</option>
      </select>
    </div>
  </div>

  <div class="filter-group">
    <label>Минимальный рейтинг (Кинопоиск)</label>
    <div class="range-controls-row">
      <input type="range" id="ratingSlider" min="1" max="10" step="0.1" value="7.0" />
      <input type="number" id="ratingInput" min="1" max="10" step="0.1" value="7.0" class="num-input-small" />
    </div>
  </div>

  <div class="filter-group">
    <label>Год выпуска</label>
    <div class="year-range-container">
      <div class="year-row">
        <span>От</span>
        <input type="range" id="yearFromSlider" min={minYear} max={maxYear} value={minYear} />
        <input type="number" id="yearFromInput" min={minYear} max={maxYear} value={minYear} class="num-input-year" />
      </div>
      <div class="year-row">
        <span>До</span>
        <input type="range" id="yearToSlider" min={minYear} max={maxYear} value={maxYear} />
        <input type="number" id="yearToInput" min={minYear} max={maxYear} value={maxYear} class="num-input-year" />
      </div>
    </div>
  </div>

  <div class="filter-group checkbox-group">
    <label class="checkbox-label">
      <input type="checkbox" id="top250Checkbox" />
      <span class="checkbox-text">Только фильмы из Топ-250 🔥</span>
    </label>
  </div>

  <button id="spinBtn" class="btn-primary">Испытать удачу 🎲</button>
</aside>

<style>
  /* ... Твои старые стили для .sidebar-filters, .type-selector и т.д. остаются без изменений ... */
  .sidebar-filters {
    background-color: #1e293b;
    padding: 1.5rem;
    border-radius: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .type-selector {
    display: flex;
    background-color: #0f172a;
    padding: 0.35rem;
    border-radius: 0.75rem;
    border: 1px solid #334155;
  }

  .type-selector input[type="radio"] {
    display: none;
  }

  .type-selector label {
    flex: 1;
    text-align: center;
    padding: 0.6rem;
    cursor: pointer;
    border-radius: 0.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: #94a3b8;
    transition:
      background-color 0.2s,
      color 0.2s;
  }

  .type-selector input[type="radio"]:checked + label {
    background-color: #334155;
    color: #f8fafc;
  }

  .sidebar-title {
    margin: 0.5rem 0 0 0;
    font-size: 1.25rem;
    border-bottom: 1px solid #334155;
    padding-bottom: 0.75rem;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-size: 0.875rem;
    color: #94a3b8;
    font-weight: 500;
  }

  /* ✨ НОВЫЕ СТИЛИ ДЛЯ КРАСИВЫХ СЕЛЕКТОВ И СТРЕЛОЧКИ ✨ */

  .select-wrapper {
    position: relative;
    display: block;
    width: 100%;
  }

  /* Делаем крупную, четкую кастомную стрелочку */
  .select-wrapper::after {
    content: "";
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 10px;
    height: 6px;
    background-color: #94a3b8; /* Цвет стрелочки по умолчанию */
    /* Рисуем аккуратный треугольник с помощью clip-path вместо кривых шрифтовых символов */
    clip-path: polygon(0 0, 100% 0, 50% 100%);
    pointer-events: none;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease;
  }

  /* Поворачиваем стрелку вверх, когда пользователь открывает селект (работает при фокусе) */
  .select-wrapper:focus-within::after {
    transform: translateY(-50%) rotate(180deg);
    background-color: #f97316; /* Стрелочка подсвечивается акцентным цветом */
  }

  select {
    width: 100%;
    appearance: none; /* Полностью скрывает уродливую стандартную стрелку Windows/Chrome/Safari */
    -webkit-appearance: none;
    -moz-appearance: none;
    background-color: #0f172a;
    color: #f8fafc;
    border: 1px solid #334155;
    padding: 0.75rem 2.5rem 0.75rem 1rem; /* Увеличили правый отступ, чтобы текст не налезал на стрелку */
    border-radius: 0.65rem; /* Сделали скругление чуть мягче */
    font-size: 0.95rem;
    font-weight: 500;
    outline: none;
    cursor: pointer;
    transition:
      border-color 0.2s,
      background-color 0.2s,
      box-shadow 0.2s;
  }

  /* Красивый интерактивный эффект при наведении */
  select:hover {
    background-color: #141f32;
    border-color: #475569;
  }

  /* Эффект фокуса с аккуратным свечением */
  select:focus {
    border-color: #f97316;
    background-color: #0f172a;
    box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.15);
  }

  /* Стилизация выпадающего списка опций (поддерживается большинством современных браузеров) */
  select option {
    background-color: #1e293b;
    color: #f8fafc;
    padding: 0.75rem;
  }

  /* ... Все остальные стили для инпутов, range и кнопок ниже остаются старыми ... */
  .checkbox-group {
    margin-top: 0.25rem;
  }
  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    cursor: pointer;
    user-select: none;
  }
  .checkbox-label input[type="checkbox"] {
    width: 18px;
    height: 18px;
    accent-color: #f97316;
    cursor: pointer;
  }
  .checkbox-text {
    font-size: 0.95rem;
    color: #f8fafc;
    font-weight: 500;
  }
  .num-input-small,
  .num-input-year {
    background-color: #0f172a;
    color: #f8fafc;
    border: 1px solid #334155;
    padding: 0.65rem;
    border-radius: 0.5rem;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .num-input-small:focus,
  .num-input-year:focus,
  input:focus {
    border-color: #f97316;
  }
  .range-controls-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  input[type="range"] {
    flex-grow: 1;
    accent-color: #f97316;
    cursor: pointer;
  }
  .num-input-small {
    width: 55px;
    text-align: center;
  }
  .year-range-container {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: rgba(0, 0, 0, 0.15);
    padding: 0.75rem;
    border-radius: 0.5rem;
  }
  .year-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
  }
  .year-row span {
    width: 20px;
    color: #94a3b8;
  }
  .num-input-year {
    width: 65px;
    text-align: center;
    padding: 0.4rem;
  }
  .btn-primary {
    background-color: #f97316;
    color: white;
    border: none;
    padding: 0.85rem;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      background-color 0.2s,
      transform 0.1s;
    margin-top: 0.25rem;
  }
  .btn-primary:hover {
    background-color: #ea580c;
  }
  .btn-primary:active {
    transform: scale(0.98);
  }
</style>
