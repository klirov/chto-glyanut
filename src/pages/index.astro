---
import localMovies from "../data/movies.json";
import FilterSidebar from "../components/FilterSidebar.astro";
import MovieCard from "../components/MovieCard.astro";
import Notification from "../components/Notification.astro";

const baseMoviesWithoutAnime = localMovies.filter((movie) => !movie.genres?.some((g) => g.toLowerCase() === "аниме"));

const allGenres = [...new Set(baseMoviesWithoutAnime.flatMap((m) => m.genres || []))].sort();

const years = baseMoviesWithoutAnime.map((m) => m.year).filter(Boolean);
const minYear = Math.min(...years) || 1900;
const maxYear = Math.max(...years) || 2026;
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="referrer" content="no-referrer" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + "favicon.svg"} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
      rel="stylesheet"
    />
    <title>Chto-glyanut</title>
  </head>
  <body>
    <Notification />

    <div class="app-container">
      <header>
        <h1>🎬 Что глянуть?</h1>
        <p class="subtitle">Идеальный выбор на вечер</p>
      </header>

      <div class="main-layout">
        <FilterSidebar allGenres={allGenres} minYear={minYear} maxYear={maxYear} />

        <main class="content-area">
          <MovieCard />
        </main>
      </div>
    </div>

    {/* Передаем в клиентский скрипт уже отфильтрованную базу */}
    <script define:vars={{ localMovies: baseMoviesWithoutAnime }}>
      // Элементы фильтров
      const spinBtn = document.getElementById("spinBtn");
      const genreSelect = document.getElementById("genreSelect");
      const countrySelect = document.getElementById("countrySelect");
      const top250Checkbox = document.getElementById("top250Checkbox");

      // КП Рейтинг
      const ratingSlider = document.getElementById("ratingSlider");
      const ratingInput = document.getElementById("ratingInput");

      // IMDb Рейтинг
      const imdbRatingSlider = document.getElementById("imdbRatingSlider");
      const imdbRatingInput = document.getElementById("imdbRatingInput");

      // Года
      const yearFromSlider = document.getElementById("yearFromSlider");
      const yearFromInput = document.getElementById("yearFromInput");
      const yearToSlider = document.getElementById("yearToSlider");
      const yearToInput = document.getElementById("yearToInput");

      // Карточка результатов
      const resultCard = document.getElementById("resultCard");
      const placeholderCard = document.getElementById("placeholderCard");
      const moviePoster = document.getElementById("moviePoster");
      const movieTitle = document.getElementById("movieTitle");
      const movieOrigTitle = document.getElementById("movieOrigTitle");
      const movieRatingKp = document.getElementById("movieRatingKp");
      const movieRatingImdb = document.getElementById("movieRatingImdb");
      const movieTop = document.getElementById("movieTop");
      const movieAge = document.getElementById("movieAge");
      const movieYear = document.getElementById("movieYear");
      const movieLength = document.getElementById("movieLength");
      const movieCountries = document.getElementById("movieCountries");
      const movieDescription = document.getElementById("movieDescription");
      const kpLink = document.getElementById("kpLink");
      const movieLogo = document.getElementById("movieLogo");
      const btnText = document.getElementById("btnText");

      // Тост
      const customNotification = document.getElementById("customNotification");
      const notificationText = document.getElementById("notificationText");
      const closeNotificationBtn = document.getElementById("closeNotificationBtn");
      let toastTimeout = null;

      function showNotification(message) {
        if (toastTimeout) clearTimeout(toastTimeout);
        notificationText.textContent = message;
        customNotification.classList.add("visible");
        toastTimeout = setTimeout(() => {
          customNotification.classList.remove("visible");
        }, 4500);
      }

      closeNotificationBtn.addEventListener("click", () => {
        customNotification.classList.remove("visible");
      });

      // Синхронизация range и number инпутов
      function setupSync(slider, input) {
        slider.addEventListener("input", () => {
          input.value = slider.value;
        });
        input.addEventListener("input", () => {
          if (input.value) slider.value = input.value;
        });
      }
      setupSync(ratingSlider, ratingInput);
      setupSync(imdbRatingSlider, imdbRatingInput);
      setupSync(yearFromSlider, yearFromInput);
      setupSync(yearToSlider, yearToInput);

      // Клик по кнопке рандома
      spinBtn.addEventListener("click", () => {
        // Получаем значение выбранного таба (movie или tv-series)
        const selectedTypeInput = document.querySelector('input[name="contentType"]:checked');
        const selectedType = selectedTypeInput ? selectedTypeInput.value : "movie";

        const selectedGenre = genreSelect.value;
        const selectedCountryType = countrySelect.value;
        const onlyTop250 = top250Checkbox.checked;
        const minRating = Number(ratingInput.value);
        const minImdbRating = Number(imdbRatingInput.value);
        const fromYear = Number(yearFromInput.value);
        const toYear = Number(yearToInput.value);

        let filtered = localMovies.filter((movie) => {
          // 1. Фильтр по типу контента (Фильм / Сериал)
          const currentType = movie.type || "movie";
          if (currentType !== selectedType) return false;

          // 2. Рейтинг Кинопоиска
          if ((movie.rating?.kp || 0) < minRating) return false;

          // 3. Рейтинг IMDb
          if ((movie.rating?.imdb || 0) < minImdbRating) return false;

          // 4. Диапазон годов
          if (movie.year < fromYear || movie.year > toYear) return false;

          // 5. Жанры
          if (selectedGenre && !movie.genres?.includes(selectedGenre)) return false;

          // 6. Флаг Топ-250
          if (onlyTop250 && !movie.top250) return false;

          // 7. Страны
          if (selectedCountryType !== "all") {
            const isRussian = movie.countries?.some((c) => c.toLowerCase() === "россия");
            if (selectedCountryType === "ru" && !isRussian) return false;
            if (selectedCountryType === "foreign" && isRussian) return false;
          }
          return true;
        });

        if (filtered.length === 0) {
          const contentTypeName = selectedType === "movie" ? "фильмов" : "сериалов";
          showNotification(`Ничего не найдено среди ${contentTypeName}! Попробуй смягчить фильтры.`);
          return;
        }

        const randomIndex = Math.floor(Math.random() * filtered.length);
        const luckyMovie = filtered[randomIndex];

        // Текст и заголовки
        movieTitle.textContent = luckyMovie.name;
        if (luckyMovie.alternativeName && luckyMovie.alternativeName !== luckyMovie.name) {
          movieOrigTitle.textContent = luckyMovie.alternativeName;
          movieOrigTitle.style.display = "block";
        } else {
          movieOrigTitle.style.display = "none";
        }

        // Лейблы рейтингов
        const kpRating = luckyMovie.rating?.kp || 0;
        const imdbRating = luckyMovie.rating?.imdb || 0;

        movieRatingKp.textContent = `КП ${kpRating.toFixed(1)}`;
        movieRatingKp.title = `Голосов: ${luckyMovie.votes?.kp?.toLocaleString("ru-RU") || 0}`;
        if (imdbRating > 0) {
          movieRatingImdb.textContent = `IMDb ${imdbRating.toFixed(1)}`;
          movieRatingImdb.title = `Голосов: ${luckyMovie.votes?.imdb?.toLocaleString("ru-RU") || 0}`;
          movieRatingImdb.style.display = "inline-block";
        } else {
          movieRatingImdb.style.display = "none";
        }

        // Топ-250 бадж
        if (luckyMovie.top250) {
          movieTop.textContent = `🔥 Топ #${luckyMovie.top250}`;
          movieTop.style.display = "inline-block";
        } else {
          movieTop.style.display = "none";
        }

        // Возраст
        if (luckyMovie.ageRating) {
          movieAge.textContent = luckyMovie.ageRating;
          movieAge.style.display = "inline-block";
        } else {
          movieAge.style.display = "none";
        }

        movieYear.textContent = `📅 ${luckyMovie.year} год`;

        // Корректный вывод длительности для сериалов/фильмов
        if (luckyMovie.movieLength) {
          movieLength.textContent =
            selectedType === "movie" ? `⏱️ ${luckyMovie.movieLength} мин.` : `⏱️ ~${luckyMovie.movieLength} мин. серия`;
        } else {
          movieLength.textContent = "⏱️ —";
        }

        movieCountries.textContent = `🌍 ${luckyMovie.countries?.join(", ") || "Неизвестно"}`;
        movieDescription.textContent = luckyMovie.shortDescription || "Описание отсутствует.";

        // Постер
        const posterSrc = luckyMovie.poster?.previewUrl || luckyMovie.poster?.url || "";
        moviePoster.src = posterSrc ? posterSrc + "?t=" + Date.now() : "";
        moviePoster.alt = luckyMovie.name;

        // Кнопка перехода и логотип
        if (luckyMovie.logo) {
          movieLogo.src = luckyMovie.logo;
          movieLogo.classList.remove("hidden");
          btnText.textContent = " на Кинопоиске ↗";
        } else {
          movieLogo.src = "";
          movieLogo.classList.add("hidden");
          btnText.textContent = "Смотреть на Кинопоиске ↗";
        }
        kpLink.href = `https://www.kinopoisk.ru/film/${luckyMovie.id}/`;

        // Смена состояния
        placeholderCard.style.display = "none";
        resultCard.classList.remove("empty");
        resultCard.scrollIntoView({ behavior: "smooth" });
      });
    </script>
  </body>
</html>

<style>
  :root {
    --bg-color: #0f172a;
    --text-main: #f8fafc;
    --text-muted: #94a3b8;
    --accent: #f97316;
  }

  body {
    margin: 0;
    font-family: "Inter", sans-serif;
    font-optical-sizing: auto;
    font-style: normal;
    background-color: var(--bg-color);
    color: var(--text-main);
    display: flex;
    justify-content: center;
    padding: 2rem 1rem;
    overflow-x: hidden;
  }

  .app-container {
    width: 100%;
    max-width: 1100px;
  }

  header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: 2.5rem;
    margin: 0 0 0.5rem 0;
    color: var(--accent);
  }

  .subtitle {
    color: var(--text-muted);
    margin: 0;
  }

  .main-layout {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 2rem;
    align-items: start;
  }

  .content-area {
    min-height: 450px;
  }

  @media (max-width: 850px) {
    .main-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
